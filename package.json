{
  "name": "prep-forge",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "pnpm --filter @prep-forge/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @prep-forge/db generate",
    "db:migrate": "pnpm --filter @prep-forge/db migrate",
    "db:push": "pnpm --filter @prep-forge/db push",
    "db:seed": "pnpm --filter @prep-forge/db seed",
    "import:legacy": "tsx scripts/import_legacy_ai_teacher.ts"
  },
  "devDependencies": {
    "@prep-forge/legacy-import": "workspace:*",
    "@types/node": "^24.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
