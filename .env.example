# Phase 0 local database (matches infra/docker-compose.yml).
# Copy to .env and adjust for Neon/Supabase/any Postgres URL if not using Docker.
DATABASE_URL=postgres://prepforge:prepforge@localhost:5432/prepforge

# Phase 2 (G7): the web BFF calls the ai-worker to generate AI draft packets.
# AI_WORKER_URL = where the worker listens (see services/ai-worker/.env.example
# AI_WORKER_HOST/PORT); AI_WORKER_SHARED_SECRET MUST equal the worker's value.
# Unset → the admin "生成草包" entry fails the job gracefully (no crash).
AI_WORKER_URL=http://127.0.0.1:8200
AI_WORKER_SHARED_SECRET=
