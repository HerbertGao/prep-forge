{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1"
    },
    "tenantId": {
      "type": "string",
      "minLength": 1
    },
    "jobId": {
      "type": "string",
      "minLength": 1
    },
    "lessonPacket": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "origin": {
          "type": "string",
          "enum": [
            "imported",
            "system",
            "ai_generated"
          ]
        },
        "visibility": {
          "type": "string",
          "enum": [
            "public",
            "personal"
          ]
        },
        "version": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "status": {
          "type": "string",
          "enum": [
            "validating",
            "draft",
            "ready",
            "consumed",
            "quarantine"
          ]
        },
        "subjectCode": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "courseCode": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "kpCodes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "prerequisites": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "estimatedMinutes": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            {
              "type": "null"
            }
          ]
        },
        "difficulty": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "objectives": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "type": "string",
                "enum": [
                  "diagnostic_question",
                  "socratic_question",
                  "explanation",
                  "math_block",
                  "worked_example",
                  "practice",
                  "hint",
                  "summary",
                  "review_prompt"
                ]
              },
              "prompt": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "mdx": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "math": {
                "anyOf": [
                  {
                    "type": "object",
                    "properties": {
                      "id": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "latex": {
                        "type": "string",
                        "minLength": 1
                      },
                      "displayMode": {
                        "type": "string",
                        "enum": [
                          "inline",
                          "block"
                        ]
                      },
                      "renderStatus": {
                        "type": "string",
                        "enum": [
                          "pending",
                          "rendered",
                          "failed"
                        ]
                      },
                      "altText": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "html": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "svgUrl": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "pngUrl": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "contentHash": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      }
                    },
                    "required": [
                      "latex",
                      "displayMode"
                    ],
                    "additionalProperties": false
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "questionIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "id",
              "type"
            ],
            "additionalProperties": false
          }
        },
        "sourceBlockId": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "contentHash": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "id",
        "origin",
        "visibility",
        "version",
        "status",
        "title",
        "kpCodes",
        "steps"
      ],
      "additionalProperties": false
    },
    "generationSources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "sourceType": {
            "type": "string",
            "enum": [
              "question",
              "question_solution"
            ]
          },
          "sourceId": {
            "type": "string",
            "minLength": 1
          },
          "modelCallIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "promptVersion": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "sourceType",
          "sourceId",
          "modelCallIds",
          "promptVersion"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "schemaVersion",
    "tenantId",
    "jobId",
    "lessonPacket",
    "generationSources"
  ],
  "additionalProperties": false
}
