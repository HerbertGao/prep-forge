{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "lessonPacketId": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "schemaPassed": {
      "type": "boolean"
    },
    "mathRenderPassed": {
      "type": "boolean"
    },
    "questionRefsPassed": {
      "type": "boolean"
    },
    "score": {
      "anyOf": [
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "passed": {
      "type": "boolean"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "schemaPassed",
    "mathRenderPassed",
    "questionRefsPassed",
    "passed"
  ],
  "additionalProperties": false
}
