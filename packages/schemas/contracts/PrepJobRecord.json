{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "running",
        "validating",
        "done",
        "failed"
      ]
    },
    "kpCode": {
      "type": "string",
      "minLength": 1
    },
    "promptVersion": {
      "type": "string",
      "minLength": 1
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1
    },
    "attemptCount": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "failureReason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "lessonPacketId": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "createdAt": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "updatedAt": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": [
    "id",
    "status",
    "kpCode",
    "promptVersion",
    "idempotencyKey",
    "attemptCount"
  ],
  "additionalProperties": false
}
