# ai-worker 运行配置（D10 信任边界）。复制为 .env 后填真值：
#   cd services/ai-worker && cp .env.example .env
# .env 已被仓根 .gitignore 忽略（.env / .env.* 除 .env.example）——绝不提交真实密钥。

# prep_worker 角色密码。G3 迁移（0006_prep_worker_role.sql）从同一 .env 取此值，
# 故 worker 与迁移共用一把密码（见迁移文件头部命令）。生成后填入。
PREP_WORKER_PASSWORD=

# worker↔BFF 共享密钥（HMAC 常量时间校验，绝不进日志）。生成后填入。
AI_WORKER_SHARED_SECRET=

# asyncpg DSN，角色 prep_worker，连 prepforge-postgres（OrbStack，宿主 127.0.0.1:5433）。
# 宿主裸跑（uvicorn 直接在宿主）用 localhost；容器内用 host.docker.internal。
# 把上面的 prep_worker 凭据填进 DSN 后再设置本行。
AI_WORKER_DATABASE_URL=

# 仅绑回环（D10）。容器内由 Dockerfile CMD 强制 0.0.0.0；对宿主的暴露仍只映射 127.0.0.1。
AI_WORKER_HOST=127.0.0.1
AI_WORKER_PORT=8200

# Claude CLI 凭据（G5 adapter 用隔离 HOME 跑真实模型调用）——运行期前提，不在此配密钥：
#   - 宿主裸跑：默认读 ~/.claude，无需额外配置。
#   - 容器内：需把宿主 ~/.claude 只读挂进容器并指向它（见 docker-compose.yml 注释）。
# CLAUDE_CONFIG_DIR=/home/appuser/.claude
